generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  auth0Id            String    @unique
  email              String    @unique
  name               String?
  picture            String?
  isAdmin            Boolean   @default(false)
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  weeklyGoalsTarget  Int       @default(5)

  boards        Board[]
  assignedItems Item[]    @relation("ItemAssignee")
  auditLogs     AuditLog[]
  comments      Comment[]
  googleToken   GoogleToken?
  weeklyGoals   WeeklyGoal[]
}

model Board {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  icon      String?
  color     String?
  type      String   @default("project")  // "project" | "inbox"
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  groups       Group[]
  columns      Column[]
  customFields CustomField[]

  @@index([ownerId])
  @@index([ownerId, type])
}

model Group {
  id       String  @id @default(uuid())
  boardId  String
  name     String
  color    String?
  position Int

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  items Item[]

  @@index([boardId])
}

model Item {
  id            String    @id @default(uuid())
  groupId       String
  name          String
  notes         String?
  position      Int
  assigneeId    String?
  scheduledDate DateTime?
  isToday       Boolean   @default(false)
  completedAt   DateTime?
  priority      String?
  category      String?
  parentId      String?
  description   String?
  deadline      DateTime?

  weeklyGoalId String?

  group        Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignee     User?              @relation("ItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  weeklyGoal   WeeklyGoal?        @relation(fields: [weeklyGoalId], references: [id], onDelete: SetNull)
  columnValues ColumnValue[]
  customValues CustomFieldValue[]
  comments     Comment[]
  parent       Item?              @relation("SubItems", fields: [parentId], references: [id], onDelete: SetNull)
  subItems     Item[]             @relation("SubItems")

  @@index([groupId])
  @@index([parentId])
  @@index([scheduledDate])
  @@index([completedAt])
  @@index([isToday])
  @@index([weeklyGoalId])
}

model WeeklyGoal {
  id         String   @id @default(uuid())
  userId     String
  weekStart  DateTime
  title      String
  isComplete Boolean  @default(false)
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items Item[]

  @@index([userId, weekStart])
}

model Column {
  id       String     @id @default(uuid())
  boardId  String
  name     String
  type     ColumnType
  position Int

  board        Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  columnValues ColumnValue[]
}

model ColumnValue {
  id       String @id @default(uuid())
  itemId   String
  columnId String
  value    String // stored as JSON string (SQLite has no Json type)

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  column Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([itemId, columnId])
}

model CustomField {
  id       String  @id @default(uuid())
  boardId  String
  name     String
  type     String  // "text" | "url" | "number" | "checkbox"
  position Int     @default(0)

  board  Board              @relation(fields: [boardId], references: [id], onDelete: Cascade)
  values CustomFieldValue[]
}

model CustomFieldValue {
  id      String @id @default(uuid())
  itemId  String
  fieldId String
  value   String // stored as JSON string

  item  Item        @relation(fields: [itemId],  references: [id], onDelete: Cascade)
  field CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([itemId, fieldId])
}

model Comment {
  id        String   @id @default(uuid())
  itemId    String
  authorId  String
  text      String
  createdAt DateTime @default(now())

  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  action     String
  targetId   String?
  targetType String?
  meta       String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model GoogleToken {
  id           String   @id @default(uuid())
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ColumnType {
  status
  priority
  date
  text
  number
  checkbox
}
